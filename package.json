{
  "name": "taxi-lead-bot-saas",
  "version": "1.0.0",
  "description": "Core architecture for multi-tenant Taxi Lead Telegram Bot SaaS platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc && node dist/index.js",
    "build": "prisma generate --schema=src/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "dotenv": "^16.4.5",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "eslint": "^9.3.0",
    "prettier": "^3.2.5",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  }
}
